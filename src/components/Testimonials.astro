---
import Card from './ui/Card.astro';
import { testimonials } from '../data/services.js';
---

<section id="testimonios" class="section-padding bg-gradient-to-br from-main/5 to-details/10">
  <div class="container-custom">
    <div class="text-center mb-16 animate-on-scroll">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        Lo que dicen nuestras 
        <span class="text-gradient">pacientes</span>
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Historias reales de mujeres que han recuperado su confianza y belleza natural
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {testimonials.map((testimonial, index) => (
        <Card class="relative animate-on-scroll-scale" style={`animation-delay: ${index * 0.2}s`}>
          <!-- Quote icon -->
          <div class="absolute -top-4 -left-4 w-12 h-12 bg-highlight rounded-full flex items-center justify-center">
            <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h4v10h-10z"/>
            </svg>
          </div>
          
          <!-- Stars -->
          <div class="flex mb-4">
            {Array.from({ length: testimonial.rating }).map(() => (
              <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
              </svg>
            ))}
          </div>
          
          <!-- Testimonial text -->
          <blockquote class="text-gray-700 mb-6 leading-relaxed">
            "{testimonial.text}"
          </blockquote>
          
          <!-- Patient info -->
          <div class="flex items-center space-x-3">
            <div class="w-12 h-12 bg-gradient-to-br from-main to-details rounded-full flex items-center justify-center text-white font-semibold">
              {testimonial.name.charAt(0)}
            </div>
            <div>
              <div class="font-semibold text-gray-900">{testimonial.name}</div>
              <div class="text-sm text-gray-600">{testimonial.age} • {testimonial.treatment}</div>
            </div>
          </div>
        </Card>
      ))}
    </div>

    <!-- Cases section -->
    <div class="mt-16 animate-on-scroll">
      <div class="text-center mb-12">
        <h3 class="text-3xl font-bold text-gray-900 mb-4">
          Casos de <span class="text-gradient">Éxito</span>
        </h3>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto">
          Resultados reales de nuestros tratamientos de armonización facial
        </p>
      </div>
      
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <!-- Case 1 -->
        <Card class="text-center group hover:scale-105 transition-all duration-300">
          <div class="relative mb-4">
            <img 
              src="/assets/Cases/Case1.png" 
              alt="Caso de éxito 1 - Tratamiento de armonización facial" 
              class="w-full aspect-square object-cover rounded-xl shadow-lg"
            />
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Reposicionamiento Facial</h4>
          <p class="text-sm text-gray-600">Pómulos y mentón con ácido hialurónico</p>
        </Card>

        <!-- Case 2 -->
        <Card class="text-center group hover:scale-105 transition-all duration-300">
          <div class="relative mb-4">
            <img 
              src="/assets/Cases/Case2.jpeg" 
              alt="Caso de éxito 2 - Tratamiento de armonización facial" 
              class="w-full aspect-square object-cover rounded-xl shadow-lg"
            />
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Rejuvenecimiento</h4>
          <p class="text-sm text-gray-600">Toxina botulínica y rellenos faciales</p>
        </Card>

        <!-- Case 3 -->
        <Card class="text-center group hover:scale-105 transition-all duration-300">
          <div class="relative mb-4">
            <img 
              src="/assets/Cases/Case3.jpeg" 
              alt="Caso de éxito 3 - Tratamiento de armonización facial" 
              class="w-full aspect-square object-cover rounded-xl shadow-lg"
            />
          </div>
          <h4 class="font-semibold text-gray-900 mb-2">Diseño Labial</h4>
          <p class="text-sm text-gray-600">Con ácido hialurónico para restaurar la forma natural de los labios</p>
        </Card>


      </div>
    </div>
  </div>
</section>

---
import Card from './ui/Card.astro';
import Form from './ui/Form.astro';
import Button from './ui/Button.astro';
---

<section id="oferta" class="section-padding bg-gradient-to-br from-highlight/10 to-main/10">
  <div class="container-custom">
    <div class="max-w-4xl mx-auto">
      <Card class="text-center">
        <div class="mb-8">
          <div class="w-20 h-20 mx-auto bg-gradient-to-br from-highlight to-main rounded-full flex items-center justify-center text-4xl mb-6">
            🎁
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
            <span class="text-gradient">Asesoría de Belleza Gratuita</span>
          </h2>
          <p class="text-xl text-gray-600 max-w-2xl mx-auto">
            Descubre qué tratamiento es perfecto para ti. Consulta personalizada sin compromiso.
          </p>
        </div>

        <div class="grid md:grid-cols-2 gap-8 items-center">
          <!-- Benefits -->
          <div class="text-left space-y-4">
            <h3 class="text-2xl font-semibold text-gray-900 mb-6">
              ¿Qué incluye tu asesoría gratuita?
            </h3>
            
            <div class="space-y-4">
              <div class="flex items-start space-x-3">
                <div class="w-6 h-6 bg-highlight rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Evaluación facial personalizada</h4>
                  <p class="text-gray-600 text-sm">Análisis detallado de tu rostro y necesidades específicas</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-3">
                <div class="w-6 h-6 bg-highlight rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Plan de tratamiento personalizado</h4>
                  <p class="text-gray-600 text-sm">Recomendaciones específicas para tus objetivos de belleza</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-3">
                <div class="w-6 h-6 bg-highlight rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Información sobre precios</h4>
                  <p class="text-gray-600 text-sm">Transparencia total en costos y opciones de pago</p>
                </div>
              </div>
              
              <div class="flex items-start space-x-3">
                <div class="w-6 h-6 bg-highlight rounded-full flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                  </svg>
                </div>
                <div>
                  <h4 class="font-semibold text-gray-900">Sin compromiso</h4>
                  <p class="text-gray-600 text-sm">Consulta completamente gratuita, sin obligación de contratar</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Form -->
          <div class="bg-white rounded-2xl p-6 shadow-lg">
            <h3 class="text-xl font-semibold text-gray-900 mb-6 text-center">
              Agenda tu asesoría gratuita
            </h3>
            
            <form id="formulario" action="https://www.fidelidapp.cl/agendalanding/68c44056670f3153316c7f88" method="GET" target="_blank">
              <div class="space-y-4">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-700 mb-2">
                    Nombre completo
                  </label>
                  <input 
                    type="text" 
                    id="name" 
                    name="name"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-highlight focus:border-transparent transition-all duration-300"
                    placeholder="Tu nombre completo"
                  />``
                </div>
                
                <div>
                  <label for="phone" class="block text-sm font-medium text-gray-700 mb-2">
                    Teléfono
                  </label>
                  <input 
                    type="tel" 
                    id="phone" 
                    name="phone"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-highlight focus:border-transparent transition-all duration-300"
                    placeholder="+56 9 1234 5678"
                  />
                </div>
                
                <div>
                  <label for="age" class="block text-sm font-medium text-gray-700 mb-2">
                    Edad
                  </label>
                  <select 
                    id="age" 
                    name="age"
                    required
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-highlight focus:border-transparent transition-all duration-300"
                  >
                    <option value="">Selecciona tu rango de edad</option>
                    <option value="25-35">25-35 años</option>
                    <option value="35-45">35-45 años</option>
                    <option value="45-55">45-55 años</option>
                    <option value="55+">55+ años</option>
                  </select>
                </div>
                
                <div>
                  <label for="interest" class="block text-sm font-medium text-gray-700 mb-2">
                    Tratamiento de interés
                  </label>
                  <select 
                    id="interest" 
                    name="interest"
                    class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-highlight focus:border-transparent transition-all duration-300"
                  >
                    <option value="">Selecciona un tratamiento</option>
                    <option value="toxina-botulinica">Toxina Botulínica</option>
                    <option value="acido-hialuronico">Ácido Hialurónico</option>
                    <option value="rejuvenecimiento">Rejuvenecimiento</option>
                    <option value="contorno">Tratamientos de contorno</option>
                    <option value="consulta-general">Consulta general</option>
                  </select>
                </div>
              </div>
              
              <Button type="submit" class="w-full mt-6">
                <span class="mr-2">🗓️</span>
                Agendar Consulta
              </Button>
            </form>
            
            <p class="text-xs text-gray-500 text-center mt-4">
              No pedimos tarjeta • Cancela cuando quieras • 100% gratuito
            </p>
          </div>
        </div>
      </Card>
    </div>
  </div>
</section>

<script>
  // Form enhancement
  const form = document.querySelector('form');
  if (form) {
    form.addEventListener('submit', function(e) {
      e.preventDefault();
      
      const formData = new FormData(form);
      const name = formData.get('name');
      const phone = formData.get('phone');
      const age = formData.get('age');
      const interest = formData.get('interest');
      
      // Create WhatsApp message
      let message = `Hola! Me interesa agendar una asesoría de belleza gratuita.\n\n`;
      message += `Nombre: ${name}\n`;
      message += `Teléfono: ${phone}\n`;
      message += `Edad: ${age}\n`;
      if (interest) {
        message += `Tratamiento de interés: ${interest}\n`;
      }
      message += `\nGracias!`;
      
      // Open WhatsApp
      const whatsappUrl = `https://wa.me/56986030096?text=${encodeURIComponent(message)}`;
      window.open(whatsappUrl, '_blank');
    });
  }
</script>

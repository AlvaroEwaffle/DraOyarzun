---
import Button from './ui/Button.astro';
import Card from './ui/Card.astro';
---

<section id="servicio-destacado" class="section-padding bg-white">
  <div class="container-custom">
    <Card class="bg-white-to-r from-highlight/10 to-main/10 border-2 border-highlight/20 animate-on-scroll-scale">
      <div class="text-center">
        <div class="text-6xl mb-4">✨</div>
        <h3 class="text-2xl font-bold text-gray-900 mb-4">
          Servicio Destacado: Botox - Toxina Botulínica
        </h3>
        <p class="text-gray-600 mb-6 max-w-2xl mx-auto">
          Nuestro tratamiento más solicitado. Elimina las arrugas de expresión de forma natural y segura, 
          manteniendo tu rostro fresco y relajado.
        </p>
        <div class="flex justify-center">
          <Button href="https://www.fidelidapp.cl/agendalanding/68c44056670f3153316c7f88" target="_blank" rel="noopener noreferrer">
            <span class="mr-2">🗓️</span>
            Consulta sobre Toxina Botulínica
          </Button>
        </div>
      </div>
    </Card>
  </div>
</section>

---
import Button from './ui/Button.astro';
---

<section class="relative min-h-screen flex items-center justify-center overflow-hidden bg-gradient-custom lg:pt-8">
  <!-- Animated Background Elements -->
  <div class="absolute inset-0 overflow-hidden">
    <!-- Floating circles -->
    <div class="absolute top-20 left-10 w-20 h-20 bg-main/20 rounded-full animate-float"></div>
    <div class="absolute top-40 right-20 w-16 h-16 bg-details/30 rounded-full animate-pulse-slow"></div>
    <div class="absolute bottom-40 left-20 w-24 h-24 bg-accent/25 rounded-full animate-bounce-slow"></div>
    <div class="absolute bottom-20 right-10 w-12 h-12 bg-highlight/30 rounded-full animate-float" style="animation-delay: 2s;"></div>
    
    <!-- Floating geometric shapes -->
    <div class="absolute top-60 left-1/4 w-8 h-8 bg-main/40 rotate-45 animate-pulse-slow"></div>
    <div class="absolute bottom-60 right-1/4 w-6 h-6 bg-details/50 rotate-12 animate-bounce-slow" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/3 right-1/3 w-10 h-10 bg-accent/30 rounded-full animate-float" style="animation-delay: 3s;"></div>
    
    <!-- Gradient orbs -->
    <div class="absolute top-1/4 left-1/3 w-32 h-32 bg-gradient-to-r from-main/20 to-details/20 rounded-full blur-xl animate-pulse-slow"></div>
    <div class="absolute bottom-1/3 right-1/3 w-40 h-40 bg-gradient-to-r from-accent/15 to-highlight/15 rounded-full blur-2xl animate-float" style="animation-delay: 2s;"></div>
  </div>

  <div class="container-custom section-padding relative z-10">
    <div class="grid lg:grid-cols-2 gap-12 items-center">
      <!-- Content -->
      <div class="text-center lg:text-left">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-gray-800 mb-6 leading-tight animate-on-scroll">
          Recupera tu <br>
          <span class="text-gradient">belleza natural</span>
          <br>con confianza
        </h1>
        
        <p class="text-xl md:text-2xl text-gray-700 mb-8 leading-relaxed animate-on-scroll" style="animation-delay: 0.2s;">
          Tratamientos de estética facial que respetan tu esencia única. 
          <strong>13 años de experiencia</strong> en salud odontológica.
        </p>
        
        <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start mb-8 animate-on-scroll" style="animation-delay: 0.4s;">
          <Button href="https://www.fidelidapp.cl/agendalanding/68c44056670f3153316c7f88" target="_blank" rel="noopener noreferrer" size="lg">
            <span class="mr-2">🗓️</span>
            Agenda tu Consulta
          </Button>
          
        </div>
        
        <!-- Social Proof -->
        <div class="flex flex-col sm:flex-row items-center justify-center lg:justify-start gap-6 text-sm text-gray-600 animate-on-scroll" style="animation-delay: 0.6s;">
          <div class="flex items-center space-x-2">
            <div class="flex -space-x-2">
              <div class="w-8 h-8 bg-main rounded-full border-2 border-white flex items-center justify-center">
                <span class="text-xs font-semibold text-gray-800">M</span>
              </div>
              <div class="w-8 h-8 bg-details rounded-full border-2 border-white flex items-center justify-center">
                <span class="text-xs font-semibold text-gray-800">C</span>
              </div>
              <div class="w-8 h-8 bg-accent rounded-full border-2 border-white flex items-center justify-center">
                <span class="text-xs font-semibold text-gray-800">P</span>
              </div>
            </div>
            <span class="font-medium">+50 mujeres han recuperado su belleza esencial</span>
          </div>
          
          <div class="flex items-center space-x-1">
            <div class="flex text-yellow-400">
              <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
              </svg>
              <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
              </svg>
              <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
              </svg>
              <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
              </svg>
              <svg class="w-4 h-4 fill-current" viewBox="0 0 20 20">
                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z"/>
              </svg>
            </div>
            <span>4.9/5 (127 reseñas)</span>
          </div>
        </div>
      </div>
      
      <!-- Image -->
      <div class="relative animate-on-scroll-right" style="animation-delay: 0.3s;">
        <img 
          src="/assets/HeroProfile.png" 
          alt="Dra. Carolina Oyarzún - Especialista en Estética Facial" 
          class="w-full max-w-lg mx-auto rounded-3xl shadow-2xl"
        />
        
        <!-- Decorative elements around image -->
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-main/20 rounded-full animate-pulse-slow"></div>
        <div class="absolute -bottom-4 -left-4 w-20 h-20 bg-details/30 rounded-full animate-float"></div>
        <div class="absolute top-1/2 -left-8 w-16 h-16 bg-accent/25 rounded-full animate-bounce-slow"></div>
      </div>
    </div>
  </div>
  
  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 transform -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"></path>
    </svg>
  </div>
</section>

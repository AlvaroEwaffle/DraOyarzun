---
import Card from './ui/Card.astro';
import { benefits } from '../data/services.js';
---

<section id="beneficios" class="section-padding bg-white">
  <div class="container-custom">
    <div class="text-center mb-16 animate-on-scroll">
      <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-4">
        ¿Por qué elegir a la 
        <span class="text-gradient">Dra. Oyarzún</span>?
      </h2>
      <p class="text-xl text-gray-600 max-w-3xl mx-auto">
        Mi propósito es acompañarte y realzar tu belleza, respetando siempre la esencia única que te hace ser tú.
      </p>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
      {benefits.map((benefit, index) => (
        <Card class="text-center group hover:scale-105 transition-all duration-300 animate-on-scroll-scale" style={`animation-delay: ${index * 0.1}s`}>
          <div class="mb-6">
            <div class="w-20 h-20 mx-auto bg-gradient-to-br from-main/20 to-details/20 rounded-full flex items-center justify-center text-4xl group-hover:scale-110 transition-transform duration-300">
              {benefit.icon}
            </div>
          </div>
          
          <h3 class="text-xl font-semibold text-gray-900 mb-4">
            {benefit.title}
          </h3>
          
          <p class="text-gray-600 leading-relaxed">
            {benefit.description}
          </p>
        </Card>
      ))}
    </div>

    <!-- Additional trust indicators -->
    <div class="mt-16 grid md:grid-cols-2 gap-8 text-center animate-on-scroll">
      <div class="bg-highlight rounded-2xl p-8 space-y-2">
        <div class="text-4xl font-bold text-white">13+</div>
        <div class="text-white/90">Años de experiencia</div>
      </div>
      
      <div class="bg-highlight rounded-2xl p-8 space-y-2">
        <div class="text-4xl font-bold text-white">100%</div>
        <div class="text-white/90">Productos certificados</div>
      </div>
    </div>
  </div>
</section>
